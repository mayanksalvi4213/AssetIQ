{
  "vendor_name": [
    "(?m)^\\s*([A-Za-z][A-Za-z0-9 .,&'\\-]*?\\s*(?:LLP|Pvt\\.?\\s*Ltd\\.?|Limited|Inc\\.?|Store|Shop|Zone|Tech|Supplies|Solutions|Peripherals|Electronics|Enterprises|Services))\\s*$",
    "(?m)^\\s*([A-Z][A-Z &]{3,}(?:STORE|SHOP|ZONE|TECH|SUPPLIES|SOLUTIONS|PERIPHERALS|ELECTRONICS)?)\\s*$"
  ],
  "vendor_address": [
    "(?:LLP|Ltd\\.?|Limited|Store|Shop|Electronics|Solutions)\\s*\\n([\\s\\S]{10,300}?)(?=\\s*(?:GSTIN|State\\s*Name|Ph|Phone|Tel|Invoice|Bill))",
    "(?:Address|Addr)\\s*:?\\s*(.+?)(?=\\n.*?(?:GSTIN|Phone|Invoice|Bill))"
  ],
  "gstin": [
    "GSTIN[/\\s]*(?:UIN)?\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][0-9A-Z][A-Z][0-9A-Z])",
    "\\b(\\d{2}[A-Z]{5}\\d{4}[A-Z]\\d[A-Z\\d][A-Z\\d])\\b",
    "GSTIN\\s*:?\\s*([0-9]{2}[A-Z0-9]{5}[0-9]{4}[A-Z0-9]{4})"
  ],
  "invoice_number": [
    "(?:Invoice|Bill)\\s*No\\.?\\s*[:\\-|]?\\s*([A-Z0-9][A-Z0-9/\\-]+)",
    "(?:Invoice|Bill)\\s*#\\s*([A-Z0-9/\\-]+)"
  ],
  "invoice_date": [
    "(?:Date|Dt)\\s*[:\\-]?\\s*(\\d{1,2}[\\-/][A-Za-z]{3,9}[\\-/]\\d{4})",
    "(?:Date|Dt)\\s*[:\\-]?\\s*(\\d{1,2}[\\-/]\\d{1,2}[\\-/]\\d{2,4})",
    "Dated\\s*[:\\-|]?\\s*(\\d{1,2}[\\-/][A-Za-z]{3,9}[\\-/]\\d{4})"
  ],
  "cgst": [
    "CGST.*?(\\d[\\d,]*\\.\\d{2})",
    "CGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-|]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "sgst": [
    "SGST.*?([\\d,]+\\.\\d{2})",
    "SGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-|]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "grand_total": [
    "TOTAL\\s*[|\\s]*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.\\d{2})",
    "(?:Grand\\s*)?Total\\s*[:\\-|]?\\s*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.\\d{2})",
    "(?:Net\\s*)?Amount\\s*[:\\-|]?\\s*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.\\d{2})"
  ],
  "batch_numbers_multi": [
    "Batch\\s*:?\\s*([A-Z0-9]{4,})",
    "(?:S(?:erial|r)\\.?\\s*No\\.?|SN|IMEI)\\s*:?\\s*([A-Z0-9]{4,})"
  ],
  "items_multi": [
    "\\|\\s*([A-Za-z][A-Za-z0-9 .&/-]{2,})\\s*\\|\\s*(\\d+)\\s*\\|\\s*([\\d,.]+)\\s*\\|",
    "(?:^|\\n)\\s*([A-Za-z][A-Za-z0-9 .&/-]{2,})\\s+([\\d]+)\\s+([\\d,.]+)\\s*$"
  ],
  "item_groups": {
    "description": 1,
    "quantity": 2,
    "total": 3
  }
}