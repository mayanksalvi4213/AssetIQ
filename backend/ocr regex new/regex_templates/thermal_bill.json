{
  "vendor_name": [
    "(?m)^\\s*([A-Z][A-Z &]{3,}(?:STORE|SHOP|MART|SUPPLIES|TECH|ZONE|CORNER|SOLUTIONS|ELECTRONICS|PERIPHERALS)?)\\s*$",
    "(?m)^\\s*([A-Za-z][A-Za-z0-9 .,&'\\-]*?\\s*(?:LLP|Pvt\\.?\\s*Ltd\\.?|Limited|Store|Shop))\\s*$"
  ],
  "vendor_address": [
    "(?:STORE|SHOP|MART|SOLUTIONS|ELECTRONICS|Ltd\\.?|Limited)\\s*\\n([\\s\\S]{10,200}?)(?=\\s*(?:GSTIN|Ph|Phone|Tel|Bill|Date))",
    "(?:Address|Addr)\\s*:?\\s*(.+)"
  ],
  "gstin": [
    "GSTIN[/\\s]*(?:UIN)?\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][0-9A-Z][A-Z][0-9A-Z])",
    "\\b(\\d{2}[A-Z]{5}\\d{4}[A-Z]\\d[A-Z\\d][A-Z\\d])\\b"
  ],
  "invoice_number": [
    "(?:Bill|Receipt|Token|Invoice)\\s*(?:No\\.?)?\\s*[:\\-]?\\s*([A-Z0-9][A-Z0-9/\\-]+)",
    "(?:Bill|Receipt)\\s*#\\s*([A-Z0-9/\\-]+)"
  ],
  "invoice_date": [
    "(?:Date|Dt)\\s*[:\\-]?\\s*(\\d{1,2}[\\-/]\\d{1,2}[\\-/]\\d{2,4})",
    "(?:Date|Dt)\\s*[:\\-]?\\s*(\\d{1,2}[\\-/][A-Za-z]{3,9}[\\-/]\\d{4})"
  ],
  "cgst": [
    "CGST.*?(\\d[\\d,]*\\.\\d{2})",
    "CGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "sgst": [
    "SGST.*?(\\d[\\d,]*\\.\\d{2})",
    "SGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "grand_total": [
    "(?:TOTAL|Grand\\s*Total|Net\\s*Amount)\\s*[:\\-]?\\s*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.?\\d{0,2})",
    "₹\\s*(\\d[\\d,]*\\.\\d{2})"
  ],
  "batch_numbers_multi": [
    "Batch\\s*:?\\s*([A-Z0-9]{4,})",
    "(?:S(?:erial|r)\\.?\\s*No\\.?|SN|IMEI)\\s*:?\\s*([A-Z0-9]{4,})"
  ],
  "items_multi": [],
  "item_groups": {}
