{
  "vendor_name": [
    "(?:Supplier|Consignor)\\s*(?:Name)?\\s*:?\\s*([A-Za-z][A-Za-z0-9 .,&'\\-]*?\\s*(?:LLP|Pvt\\.?\\s*Ltd\\.?|Limited|Inc\\.?|Corporation|Enterprises|Solutions|Technologies|Services))",
    "(?m)^\\s*([A-Za-z][A-Za-z0-9 .,&'\\-]*?\\s*(?:LLP|Pvt\\.?\\s*Ltd\\.?|Limited|Inc\\.?|Corporation))\\s*$"
  ],
  "vendor_address": [
    "(?:Supplier|Consignor)\\s*Address\\s*:?\\s*(.+?)(?=\\n|GSTIN|State)",
    "(?:From|Dispatch\\s*From)\\s*:?\\s*([A-Za-z][A-Za-z0-9 ,\\.\\-]+)"
  ],
  "gstin": [
    "(?:GSTIN|GST)\\s*(?:of)?\\s*(?:Supplier|Consignor)\\s*:?\\s*(\\d{2}[A-Z]{5}\\d{4}[A-Z]\\d[A-Z\\d][A-Z\\d])",
    "GSTIN[/\\s]*UIN\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][0-9A-Z][A-Z][0-9A-Z])",
    "\\b(\\d{2}[A-Z]{5}\\d{4}[A-Z]\\d[A-Z\\d][A-Z\\d])\\b"
  ],
  "invoice_number": [
    "(?:Document|Doc)\\s*No\\.?\\s*[:\\-]?\\s*([A-Z0-9][A-Z0-9/\\-]+)",
    "(?:Invoice)\\s*No\\.?\\s*[:\\-]?\\s*([A-Z0-9/\\-]+)"
  ],
  "invoice_date": [
    "(?:Document|Doc)\\s*Date\\s*[:\\-]?\\s*(\\d{1,2}[\\-/]\\d{1,2}[\\-/]\\d{2,4})",
    "(?:Document|Doc)\\s*Date\\s*[:\\-]?\\s*(\\d{1,2}[\\-/][A-Za-z]{3,9}[\\-/]\\d{4})"
  ],
  "cgst": [
    "CGST.*?(\\d[\\d,]*\\.\\d{2})",
    "CGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "sgst": [
    "SGST.*?(\\d[\\d,]*\\.\\d{2})",
    "SGST\\s*(?:@\\s*\\d+%)?\\s*[:\\-]?\\s*([\\d,]+\\.\\d{2})"
  ],
  "grand_total": [
    "₹\\s*(\\d[\\d,]*\\.\\d{2})",
    "(?:Total|Invoice)\\s*Value\\s*[:\\-]?\\s*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.?\\d{0,2})",
    "(?:Grand\\s*)?Total\\s*[:\\-]?\\s*(?:Rs\\.?|INR|₹)?\\s*([\\d,]+\\.\\d{2})"
  ],
  "eway_bill_number": [
    "(?:E-?Way\\s*Bill\\s*No|EWB\\s*No)\\.?\\s*:?\\s*([0-9]{12})"
  ],
  "vehicle_number": [
    "Vehicle\\s*No\\.?\\s*:?\\s*([A-Z]{2}\\d{1,2}[A-Z]{0,2}\\d{4})"
  ],
  "batch_numbers_multi": [
    "Batch\\s*:?\\s*([A-Z0-9]{4,})",
    "(?:S(?:erial|r)\\.?\\s*No\\.?|SN)\\s*:?\\s*([A-Z0-9]{4,})"
  ],
  "items_multi": [
    "\\|\\s*(\\d+)\\s*\\|\\s*(.+?)\\s*\\|\\s*(\\d{4,8})\\s*\\|\\s*([\\d,.]+)\\s*\\|\\s*([\\d,.]+)\\s*\\|\\s*([\\d,.]+)\\s*\\|"
  ],
  "item_groups": {
    "description": 2,
    "quantity": 4,
    "rate": 5,
    "total": 6
  }
}