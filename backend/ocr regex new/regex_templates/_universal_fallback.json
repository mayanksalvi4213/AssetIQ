{
  "vendor_name": [
    "^(?:\\s*)([A-Z][A-Za-z0-9&.,\\x27\\- ]{4,})\\s*(?=\\n)",
    "(?:Tax\\s*Invoice[\\s\\S]{0,100}?\\n)\\s*([A-Z][A-Za-z0-9&.,\\x27\\- ]{4,})",
    "^\\s*([A-Za-z][A-Za-z0-9&.,\\x27\\- ]{4,})\\s*\\n(?=.*GSTIN)"
  ],
  "vendor_address": [
    "(?:[A-Z][A-Za-z0-9&.,\\x27\\- ]{4,}\\s*\\n)([\\s\\S]{10,200}?\\d{6})",
    "(?:Address|Addr\\.?)[ :]*([\\s\\S]{5,200}?\\d{6})"
  ],
  "gstin": [
    "\\b([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{4})\\b",
    "GSTIN\\s*[/:]?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{4})",
    "GSTIN\\/UIN\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{4})"
  ],
  "pan_number": [
    "PAN\\s*(?:Number|No\\.?)?\\s*:?\\s*([A-Z]{5}[0-9]{4}[A-Z])",
    "\\b([A-Z]{5}[0-9]{4}[A-Z])\\b"
  ],
  "invoice_number": [
    "(?:Invoice|Bill|Receipt|Memo|Voucher|Document|Doc)\\s*(?:No|Number|#|Num)\\.?\\s*[:\\-]?\\s*([A-Za-z0-9\\/\\-]{2,})",
    "Tax\\s*Invoice\\s*(?:No|Number)\\s*[:\\-]?\\s*([A-Za-z0-9\\/\\-]{2,})"
  ],
  "invoice_date": [
    "(?:Invoice|Bill|Document|Doc)?\\s*Date\\s*[:\\-]?\\s*([0-9]{1,2}[\\-/][0-9]{1,2}[\\-/][0-9]{2,4})",
    "(?:Invoice|Bill)?\\s*Date\\s*[:\\-]?\\s*([0-9]{1,2}\\s+[A-Za-z]+\\s+[0-9]{4})",
    "Dated\\s*[:\\-]?\\s*([0-9]{1,2}-[A-Za-z]{3}-[0-9]{2,4})",
    "\\b([0-9]{1,2}[\\-/][0-9]{1,2}[\\-/][0-9]{4})\\b"
  ],
  "buyer_name": [
    "(?:Bill|Billed|Sold)\\s*To\\s*[:\\-,]?\\s*\\n?\\s*([A-Za-z][A-Za-z0-9&.,\\x27\\- ]{3,})",
    "Buyer\\s*(?:\\(Bill\\s*to\\))?\\s*[:\\-]?\\s*\\n?\\s*([A-Za-z][A-Za-z0-9&.,\\x27\\- ]{3,})",
    "Customer\\s*(?:Name)?\\s*[:\\-]?\\s*([A-Za-z][A-Za-z0-9&.,\\x27\\- ]{3,})",
    "Client\\s*(?:Name)?\\s*[:\\-]?\\s*([A-Za-z][A-Za-z0-9&.,\\x27\\- ]{3,})"
  ],
  "buyer_gstin": [
    "Buyer\\s*GSTIN\\s*[:\\-]?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{3})",
    "GSTIN\\s*[:\\-]?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{3})"
  ],
  "place_of_supply": [
    "Place\\s*of\\s*Supply\\s*[:\\-]?\\s*([A-Za-z][A-Za-z ]+)",
    "State\\s*(?:Name)?\\s*[:\\-]?\\s*([A-Za-z][A-Za-z ]+)"
  ],
  "hsn_code": [
    "\\bHSN[/\\s]*(?:SAC)?\\s*[:\\-]?\\s*(\\d{4,8})",
    "\\|\\s*(\\d{4,8})\\s*\\|"
  ],
  "cgst": [
    "CGST\\s*(?:@?\\s*[0-9.]+%?)?\\s*(?:Amt|Amount)?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*[:\\s|]?\\s*([0-9,]+\\.?\\d*)",
    "CGST\\s*(?:Amount)?\\s*[:\\-|]?\\s*([0-9,]+\\.\\d{2})"
  ],
  "sgst": [
    "SGST\\s*(?:@?\\s*[0-9.]+%?)?\\s*(?:Amt|Amount)?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*[:\\s|]?\\s*([0-9,]+\\.?\\d*)",
    "SGST\\s*(?:Amount)?\\s*[:\\-|]?\\s*([0-9,]+\\.\\d{2})"
  ],
  "igst": [
    "IGST\\s*(?:@?\\s*[0-9.]+%?)?\\s*(?:Amt|Amount)?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*[:\\s]?\\s*([0-9,]+\\.?\\d*)",
    "IGST\\s*(?:Amount)?\\s*[:\\-]?\\s*([0-9,]+\\.\\d{2})"
  ],
  "taxable_amount": [
    "Taxable\\s*(?:Amount|Value)\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*([0-9,]+\\.?\\d*)"
  ],
  "grand_total": [
    "TOTAL\\s*[|\\s]*(?:Rs?\\.?|[\\u20b9]|INR)\\s*([0-9,]+\\.\\d{2})",
    "(?:Grand|Net|Invoice)?\\s*(?:Total|Amount)\\s*(?:Amount|Value|Payable)?\\s*(?:\\(in\\s*figure\\))?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*([0-9,]*[0-9]{3,}\\.?\\d*)",
    "(?:Rs?\\.?|[\\u20b9]|INR)\\s*([0-9,]+\\.\\d{2})"
  ],
  "discount": [
    "Discount\\s*[:\\|]?\\s*-?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*([0-9,]+\\.?\\d*)"
  ],
  "received_amount": [
    "Received\\s*(?:Amount)?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR|Rs:)?\\s*([0-9,]+\\.?\\d*)"
  ],
  "due_balance": [
    "(?:Due|Balance)\\s*(?:Balance|Due|Amount)?\\s*[:\\|]?\\s*(?:Rs?\\.?|[\\u20b9]|INR)?\\s*([0-9,]+\\.?\\d*)"
  ],
  "items_multi": [
    "\\|\\s*([A-Za-z][A-Za-z0-9 .&/-]{2,})\\s*\\|\\s*(\\d+)\\s*\\|\\s*([\\d,.]+)\\s*\\|"
  ],
  "item_groups": {
    "description": 1,
    "quantity": 2,
    "total": 3
  },
  "batch_numbers_multi": [
    "(?:Batch|Serial|Sr\\.?)\\s*(?:No\\.?)?\\s*:?\\s*([A-Z0-9]{6,20})"
  ],
  "bank_account": [
    "Account\\s*(?:Number|No)\\.?\\s*[:\\-]?\\s*([0-9]{8,20})"
  ],
  "ifsc": [
    "IFSC\\s*(?:Code)?\\s*[:\\-]?\\s*([A-Z]{4}0[A-Z0-9]{6})"
  ],
  "upi_id": [
    "\\b([A-Za-z0-9._-]+@[A-Za-z]+)\\b"
  ]
}