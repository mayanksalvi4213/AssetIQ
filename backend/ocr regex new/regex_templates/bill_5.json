{
  "vendor_name": [
    "^\\s*([A-Za-z][A-Za-z\\s.&,'-]{4,})\\s*\\n(?=.*GSTIN)"
  ],
  "vendor_address": [
    "^[A-Za-z][A-Za-z\\s.&,'-]{4,}\\s*\\n([^\\n]+\\d{6})"
  ],
  "gstin": [
    "GSTIN\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{3})"
  ],
  "invoice_number": [
    "Invoice\\s*No\\s*:?\\s*([A-Za-z0-9\\-\\/]+)"
  ],
  "invoice_date": [
    "Invoice\\s*Date\\s*:?\\s*([0-9]{1,2}\\s+[A-Za-z]+\\s+[0-9]{4})"
  ],
  "buyer_name": [
    "BILL\\s*TO\\s*\\n\\s*([A-Za-z][A-Za-z\\s.'-]{3,})"
  ],
  "buyer_gstin": [
    "GSTIN\\s*:?\\s*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z0-9]{3})"
  ],
  "cgst": [
    "CGST\\s*@\\s*[0-9.]+%\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "sgst": [
    "SGST\\s*@\\s*[0-9.]+%\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "taxable_amount": [
    "Taxable\\s*Amount\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "grand_total": [
    "Total\\s*Amount\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "received_amount": [
    "Received\\s*Amount\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "due_balance": [
    "Due\\s*Balance\\s*\\|?\\s*Rs\\.\\s*([0-9,]+\\.?[0-9]*)"
  ],
  "items_multi": [
    "\\|\\s*([^|\\n]{2,}?)\\s*\\|\\s*([0-9]+)\\s*(?:KG|NOS|PCS|UNIT|SET|BOX|EA|DOZ|MTR|LTR|GM)?\\s*\\|\\s*Rs\\.?\\s*([0-9,.]+)\\s*\\|\\s*Rs\\.?\\s*([0-9,.]+).*?\\|\\s*Rs\\.?\\s*([0-9,.]+)"
  ],
  "item_groups": {
    "description": 1,
    "quantity": 2,
    "rate": 3,
    "tax_per_unit": 4,
    "total": 5
  }
}